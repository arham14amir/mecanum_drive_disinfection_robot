</joint>

<link name="rear_right_wheel">
  <visual>
    <origin xyz="-0.034 -0.03 -0.034" rpy="0 0 -1.5709"/>
    <geometry>
      <mesh filename="package://mecanum_drive/meshes/tyre.STL" scale="-0.001 0.001 0.001"/>
    </geometry>
  </visual>
  <collision>
    <origin xyz="-0.03 -0.03 -0.034" rpy="0 0 -1.5709"/>
    <geometry>
      <mesh filename="package://mecanum_drive/meshes/tyre.STL" scale="-0.001 0.001 0.001"/>
    </geometry>
    <surface>
      <friction>
        <ode>
          <mu>2</mu>
